# Canonical site URL for metadata, Open Graph, sitemap, robots (default: https://waitlist.fashnect.com)
# NEXT_PUBLIC_SITE_URL=https://waitlist.fashnect.com

# Supabase (existing)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SMTP (Nodemailer) — required for welcome + team emails after waitlist signup
# Without these, signup still saves but returns 502 and no mail is sent.
#
# Resend (example): host smtp.resend.com, user resend, pass = API key, port 587,
#   SMTP_FROM must be a verified domain address e.g. waitlist@yourdomain.com
# Gmail: use an App Password (Google Account → Security), not your normal password
#   SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_USER=you@gmail.com  SMTP_PASS=xxxx
#
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# From header — use a domain your provider allows (Resend verified domain, Gmail = your address)
SMTP_FROM=

# WhatsApp community invite links (server-side; returned to client after signup)
WHATSAPP_SELLER=
WHATSAPP_BUYER=

# Internal notifications
TEAM_EMAIL=
