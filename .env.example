# Optional: canonical site URL for metadata / Open Graph (defaults to https://fashnect.com)
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Supabase (existing)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SMTP (Nodemailer)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Optional; defaults to SMTP_USER if unset
SMTP_FROM=

# WhatsApp community invite links (server-side; returned to client after signup)
WHATSAPP_SELLER=
WHATSAPP_BUYER=

# Internal notifications
TEAM_EMAIL=
